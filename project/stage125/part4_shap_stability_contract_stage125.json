    "top5_features"
  ],
  "shap_for_feature_selection": false,
  "stability_across": [
    "temporal_validation_folds",
    "RF_XGBoost_seeds",
    "final_test_versus_development_OOF_explanations"
  ],
  "stability_checks": [
    "pairwise_Spearman_rank_correlation",
    "top5_Jaccard_overlap",
    "mean_sign_agreement"
  ]
}
